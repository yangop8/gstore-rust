PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ub: <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#>
SELECT ?X WHERE
{
    { ?X rdf:type ub:FullProfessor}
    UNION
    { ?X rdf:type ub:AssociateProfessor }
    UNION
    { ?X rdf:type ub:AssistantProfessor }
    UNION
    { ?X rdf:type ub:Lecturer }
    UNION
    { ?X rdf:type ub:GraduateStudent }
    UNION
    { ?X rdf:type ub:UndergraduateStudent }
    UNION
    { ?X ub:undergraduateDegreeFrom <http://www.University0.edu> }
    UNION
    { ?X ub:masterDegreeFrom <http://www.University0.edu> }
    UNION
    { ?X ub:doctoralDegreeFrom <http://www.University0.edu> }
}
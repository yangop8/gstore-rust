PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ub: <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#>
SELECT ?X ?Y ?Z
WHERE
{
    { ?X rdf:type ub:UndergraduateStudent } union { ?X rdf:type ub:GraduateStudent }
    { ?Y rdf:type ub:AssistantProfessor } UNION { ?Y rdf:type ub:FullProfessor } UNION { ?Y rdf:type ub:AssistantProfessor } UNION { ?Y rdf:type ub:Lecturer }
    ?Z rdf:type ub:Course .
    ?X ub:advisor ?Y .
    ?Y ub:teacherOf ?Z .
    ?X ub:takesCourse ?Z.
}